# ===========================================
# Folio — Environment Variables
# ===========================================

# --- Provider Switch ---
# Set to 'true' to use Anthropic Claude (recommended for best quality).
# Set to 'false' or leave unset to use Groq (faster, free tier).
USE_CLAUDE=false

# --- Anthropic (Claude) ---
# Required if USE_CLAUDE=true
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Groq ---
# Required if USE_CLAUDE=false
# Get your key at: https://console.groq.com/
GROQ_API_KEY=gsk_...

# --- Firebase Admin (Firestore) ---
# Required for /api/deploy and /site/[id] portfolio hosting.
# Create a service account in Firebase Console → Project Settings → Service accounts
# → Generate new private key. Copy the fields from the downloaded JSON.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the full private key exactly as-is (including -----BEGIN/END PRIVATE KEY-----)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"

# --- Upstash Redis (Rate Limiting) ---
# Required for the 3-generations-per-24h rate limiter on /api/generate.
# Create a free Redis database at: https://console.upstash.com/
# Copy the REST URL and token from: Database → REST API → .env tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
